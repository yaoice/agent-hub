# 应用密钥：用于签发 JWT 以及派生 Provider 密钥的加密 Key（生产环境务必修改为随机长字符串）
# 生成方式（任选其一）：
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=please-change-me-to-a-long-random-secret-string

# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=720

# 默认管理员账号（仅首次初始化时生效）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin

# 数据库连接（SQLite 默认；切换 MySQL 见下方示例）
DATABASE_URL=sqlite:///./agent_hub.db
# MySQL 示例（需安装 pymysql）：
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/agent_hub?charset=utf8mb4

# 仓储后端实现（内置 sqlalchemy）
REPOSITORY_BACKEND=sqlalchemy

# SSRF 防护：是否允许访问内网/私有地址（默认 false，仅在确有内网网关需求时设为 true）
ALLOW_INTERNAL_HOSTS=false

# 对话同步最小间隔（秒）：手动同步限频，两次之间至少间隔该时长，避免频繁全量拉取拖垮性能；0 表示不限制
CONV_SYNC_MIN_INTERVAL_SECONDS=300
